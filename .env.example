# Copy to .env and adjust if needed:  cp .env.example .env
# Only port 3000 must be reachable from your browser/phone.

# Mobile camera QR links (auto-detected by start script when possible)
# PUBLIC_BASE_URL=http://192.168.1.100:3000

# Secrets — change in production
SECRET_KEY=change-me-in-production-use-openssl-rand
POSTGRES_PASSWORD=sentinel_secret

# Optional overrides (defaults work inside Docker network)
# DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_secret@postgres:5432/sentinel_ai
# EDGE_AI_URL=http://edge-ai:8001
